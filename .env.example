# Environment Configuration Module
# Copy this to .env and fill in your details

# Your API Tokens (needed for the client)
HF_TOKEN="your_huggingface_token_here"
GROQ_API_KEY="your_groq_key_here"       # Get at console.groq.com
GEMINI_API_KEY="your_gemini_key_here"   # Get at aistudio.google.com
MISTRAL_API_KEY="your_mistral_key_here" # Get at console.mistral.ai

# Environment Server Configuration
ENV_BASE_URL="http://127.0.0.1:7860"

# Optional: delay (seconds) between task runs to stay within rate limits
# Set to 2 for Mistral free tier, 0 for Groq/Gemini
REQUEST_DELAY="0"

# ── LLM Client Configuration (Switch by uncommenting one) ────────────

# 1. Groq - Llama 3.3 70B (RECOMMENDED - fastest, generous free tier)
#    Get key: https://console.groq.com (no credit card needed)
#    Free: ~1,000 req/day, 30 RPM
API_BASE_URL="https://api.groq.com/openai/v1"
MODEL_NAME="llama-3.3-70b-versatile"
API_KEY="${GROQ_API_KEY}"

# 2. Google Gemini 2.5 Flash (best quality-per-cost)
#    Get key: https://aistudio.google.com (no credit card needed)
#    Free: ~15 RPM, 1,500 req/day
# API_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# MODEL_NAME="gemini-2.5-flash"
# API_KEY="${GEMINI_API_KEY}"

# 3. Mistral AI - Mistral Small (strong reasoning)
#    Get key: https://console.mistral.ai (phone verification only)
#    Free: ~1-2 RPM (set REQUEST_DELAY=2)
# API_BASE_URL="https://api.mistral.ai/v1"
# MODEL_NAME="mistral-small-latest"
# API_KEY="${MISTRAL_API_KEY}"

# 4. Hugging Face Router - Qwen 72B
#    Get key: https://huggingface.co/settings/tokens
#    Free: rate-limited, occasional cold starts
# API_BASE_URL="https://router.huggingface.co/v1"
# MODEL_NAME="Qwen/Qwen2.5-72B-Instruct"
# API_KEY="${HF_TOKEN}"

# 5. Groq - Llama 3.1 8B (highest throughput, lower accuracy)
#    Same key as option 1
#    Free: ~14,400 req/day - great for stress testing
# API_BASE_URL="https://api.groq.com/openai/v1"
# MODEL_NAME="llama-3.1-8b-instant"
# API_KEY="${GROQ_API_KEY}"
